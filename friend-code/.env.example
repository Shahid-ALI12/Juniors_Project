# ============================================================
# Danish Cattle Feed — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# ============================================================

# --- Supabase (PUBLIC — safe to expose in browser) ---
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_KEY=your-anon-key-here

# --- Supabase SERVICE ROLE key (SERVER-ONLY — NEVER expose in browser) ---
# Used by API routes to bypass RLS. Keep this secret!
# Supabase Dashboard → Project Settings → API → "service_role" secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Customer session token signing secret (SERVER-ONLY) ---
# Generate a random 32+ byte string. Run:  openssl rand -hex 32
CUSTOMER_TOKEN_SECRET=replace-with-a-long-random-secret
